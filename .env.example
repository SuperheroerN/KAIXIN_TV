# ========================================
# KAIXIN TV 环境变量配置
# ========================================
# 
# 📝 使用说明：
# 
# 本地开发：
# 1. 复制此文件为 .env
#    Windows: copy .env.example .env
#    Linux/Mac: cp .env.example .env
# 2. 根据需要修改 .env 文件中的配置
# 3. 启动开发服务器：pnpm dev
# 
# Cloudflare Pages 部署：
# 1. 不需要 .env 文件
# 2. 在 Cloudflare Pages 控制台设置环境变量
# 3. Settings → Environment variables → Add variable
# 
# Vercel/Netlify 部署：
# 1. 不需要 .env 文件
# 2. 在各自的控制台设置环境变量
# 
# Docker 部署：
# 1. 可以使用 .env 文件
# 2. 或在 docker-compose.yml 中设置
# 
# ⚠️ 注意：
# - .env 文件不会被提交到 Git（已在 .gitignore 中排除）
# - 生产环境请在部署平台设置环境变量
# - 所有变量必须以 VITE_ 开头才能在前端使用
# 
# ========================================

# ========================================
# 视频源配置
# ========================================
# 
# 配置多个视频源，搜索时会同时查询所有源
# 
# ⚠️ Cloudflare Pages 部署时推荐使用简单格式！
# 
# 格式1：简单格式（推荐用于 Cloudflare Pages）
# 使用 | 分隔名称和URL，使用 , 分隔多个源
# 
# 示例：
# VITE_INITIAL_VIDEO_SOURCES=无尽资源|https://api.wujinapi.me/api.php/provide/vod,茅台资源|https://caiji.maotaizy.cc/api.php/provide/vod,猫眼资源|https://api.maoyanapi.top/api.php/provide/vod
# 
# 格式2：JSON 格式（本地开发推荐）
# JSON 数组，每个源包含以下字段：
# - name: 源名称（必需）
# - url: API 地址（必需）
# - isEnabled: 是否启用（可选，默认 true）
# 
# 示例：
VITE_INITIAL_VIDEO_SOURCES=[{"name":"无尽资源","url":"https://api.wujinapi.me/api.php/provide/vod","isEnabled":true},{"name":"茅台资源","url":"https://caiji.maotaizy.cc/api.php/provide/vod","isEnabled":true},{"name":"猫眼资源","url":"https://api.maoyanapi.top/api.php/provide/vod","isEnabled":true}]
# 
# 💡 提示：
# - 源的顺序决定搜索结果的显示顺序
# - 第一个源的结果会优先显示
# - 可以添加任意数量的源
# - 不支持搜索的源会被自动跳过
# 
# ========================================

# ========================================
# 访问密码（可选）
# ========================================
# 
# 设置访问密码后，用户必须输入正确密码才能访问网站
# 留空表示公开访问，任何人都可以访问
# 
# 示例：
# VITE_ACCESS_PASSWORD=my_secret_password_123
# 
# 防暴力破解机制：
# - 3次失败 → 锁定 30秒
# - 4次失败 → 锁定 1分钟
# - 5次失败 → 锁定 2分钟
# - 6次及以上 → 锁定时间递增
# 
# 💡 提示：
# - 密码建议使用字母+数字组合，至少8位
# - 不要使用过于简单的密码
# - 定期更换密码
# - 这是简单的访问控制，不是高安全级别认证
# 
VITE_ACCESS_PASSWORD=

# ========================================
# 分析配置（可选）
# ========================================
# 
# 禁用分析跟踪
# 
VITE_DISABLE_ANALYTICS=true

# ========================================
# Docker 构建配置（可选）
# ========================================
# 
# 以下变量用于 Docker 镜像标签和元数据
# 通常在 CI/CD 流程中自动设置，本地开发无需配置
# 
BUILD_DATE=
VCS_REF=
VERSION=

# ========================================
# 部署平台环境变量设置指南
# ========================================
# 
# Cloudflare Pages:
# 1. 进入项目 → Settings → Environment variables
# 2. 点击 "Add variable"
# 3. 添加以下变量：
#    - VITE_INITIAL_VIDEO_SOURCES
#    - VITE_ACCESS_PASSWORD (可选)
# 4. 选择环境：Production / Preview
# 5. 点击 Save
# 6. 重新部署项目
# 
# Vercel:
# 1. 进入项目 → Settings → Environment Variables
# 2. 添加变量
# 3. 选择环境：Production / Preview / Development
# 4. 点击 Save
# 5. 重新部署
# 
# Netlify:
# 1. 进入项目 → Site settings → Environment variables
# 2. 点击 "Add a variable"
# 3. 添加变量
# 4. 点击 Save
# 5. 触发重新部署
# 
# Docker:
# 在 docker-compose.yml 中设置：
# 
# services:
#   kaixin-tv:
#     environment:
#       - VITE_INITIAL_VIDEO_SOURCES=[...]
#       - VITE_ACCESS_PASSWORD=your_password
# 
# 或使用 .env 文件：
# docker-compose --env-file .env up -d
# 
# ========================================


# ========================================
# 常见问题排查
# ========================================
# 
# 问题1：部署后视频源不显示
# 原因：VITE_INITIAL_VIDEO_SOURCES 未配置或格式错误
# 解决：
# 1. 检查环境变量是否添加
# 2. 验证 JSON 格式是否正确（使用 jsonlint.com）
# 3. 确保 JSON 是单行，没有换行符
# 4. 重新部署
# 
# 问题2：搜索不到视频
# 原因：视频源不支持搜索或暂时不可用
# 解决：
# 1. 更换其他视频源
# 2. 检查浏览器控制台错误
# 3. 测试视频源 API 是否可访问
# 
# 问题3：豆瓣推荐不显示
# 原因：网络问题或代理失败
# 解决：
# 1. 检查网络连接
# 2. 查看浏览器控制台错误
# 3. 稍后再试（可能是 API 限流）
# 
# 问题4：访问密码无效
# 原因：环境变量未生效或浏览器缓存
# 解决：
# 1. 确认环境变量已保存
# 2. 重新部署项目
# 3. 清除浏览器缓存
# 4. 使用无痕模式测试
# 
# 问题5：图片不显示
# 原因：防盗链或代理失败
# 解决：
# 1. 检查代理中间件是否正常
# 2. 查看浏览器控制台网络请求
# 3. 确认图片 URL 格式正确
# 
# ========================================

# ========================================
# 视频源测试方法
# ========================================
# 
# 方法1：浏览器测试
# 1. 打开浏览器
# 2. 访问：https://api.wujinapi.me/api.php/provide/vod?ac=list
# 3. 如果返回 XML/JSON 数据，说明源可用
# 
# 方法2：搜索测试
# 1. 在网站搜索框输入"流浪地球"
# 2. 查看是否有搜索结果
# 3. 如果某个源没有结果，可能不支持搜索
# 
# 方法3：命令行测试（开发者）
# curl "https://api.wujinapi.me/api.php/provide/vod?ac=list"
# 
# ========================================

